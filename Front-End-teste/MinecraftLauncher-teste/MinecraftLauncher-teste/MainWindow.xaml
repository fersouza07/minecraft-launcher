<Window x:Class="MinecraftLauncher_teste.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MinecraftLauncher_teste"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#1e1e2e">
        <Grid.RowDefinitions>
            <RowDefinition Height="0*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Width="300" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Row="1">
            <TextBlock Text="Fernandin Launcher"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

            <TextBlock Text="Nick"
                   Foreground="White"/>

            <TextBox Name="NickTextBox"
                 Height="35"
                 Margin="0,5,0,15"/>

            <TextBlock Text="Versão"
                   Foreground="White"/>

            <ComboBox Name="VersaoComboBox"
                  Height="35"
                  Margin="0,5,0,25"/>

            <Button Content="Jogar"
                Height="45"
                FontSize="18"
                FontWeight="Bold"
                Click="Jogar_Click"/>
            <ProgressBar Name="BarraProgresso"
             Height="18"
             Minimum="0"
             Maximum="100"
             Value="0"
             Margin="0,15,0,5"/>

            <TextBlock Name="StatusText"
           Text="Aguardando..."
           Foreground="White"
           HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
